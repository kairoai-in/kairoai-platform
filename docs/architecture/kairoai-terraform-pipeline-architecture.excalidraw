      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Terraform 1.8.5 | Conftest 0.56.0\nPR permissions: contents:read, id-token:write, pull-requests:read\nApply uses the same minimum GitHub permissions\nPR concurrency cancels stale runs per PR\nApply concurrency serializes each base branch and never cancels\nAzureRM environment variables select the mapped subscription",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Terraform 1.8.5 | Conftest 0.56.0\nPR permissions: contents:read, id-token:write, pull-requests:read\nApply uses the same minimum GitHub permissions\nPR concurrency cancels stale runs per PR\nApply concurrency serializes each base branch and never cancels\nAzureRM environment variables select the mapped subscription",
      "lineHeight": 1.25
    },
